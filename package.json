{
  "name": "@particle-academy/fancy-brand-icons",
  "version": "0.1.0",
  "description": "Brand-icon addendum pack for @particle-academy/react-fancy — curated CC0 brand marks (Simple Icons) layered on top of Lucide via registerIconAddendum, plus a seam for your own app logos. Zero runtime deps; SVG path data inlined.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-brand-icons.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-brand-icons#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-brand-icons/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "gen": "tsx scripts/generate.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@particle-academy/react-fancy": ">=4.7",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@particle-academy/react-fancy": "^4.7.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^13.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
